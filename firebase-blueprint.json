{
  "projectId": "gen-lang-client-0117923835",
  "collections": {
    "users": {
      "path": "users/{userId}",
      "description": "User profiles and global setup configuration",
      "fields": {
        "email": { "type": "string", "maxLength": 256, "required": true },
        "createdAt": { "type": "timestamp", "required": true },
        "updatedAt": { "type": "timestamp", "required": true }
      }
    },
    "tasks": {
      "path": "users/{userId}/tasks/{taskId}",
      "description": "User's individual worklog tasks with plan & progress tracker details",
      "fields": {
        "id": { "type": "string", "maxLength": 128, "required": true },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "required": true },
        "title": { "type": "string", "maxLength": 512, "required": true },
        "category": { "type": "string", "enum": ["Content Marketing", "Product Marketing", "Demand Generation", "Sales Enablement", "Customer Marketing", "Website & CRO", "Market Research", "Analytics & Reporting", "Campaign Management", "Operations"], "required": true },
        "status": { "type": "string", "enum": ["To Do", "In Progress", "Done"], "required": true },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"], "required": true },
        "isCaseStudyOrInsight": { "type": "boolean", "required": true },
        "notes": { "type": "string", "maxLength": 4096, "required": false },
        "duration": { "type": "string", "maxLength": 64, "required": false },
        "deliverableLink": { "type": "string", "maxLength": 2048, "required": false },
        "kpiImpact": { "type": "string", "enum": ["Social Content", "Email Campaign", "Sales Asset / Case Study", "None"], "required": false }
      }
    },
    "backlogTasks": {
      "path": "users/{userId}/backlogTasks/{backlogId}",
      "description": "Ideas and ideas backlog board for growth marketing activities",
      "fields": {
        "id": { "type": "string", "maxLength": 128, "required": true },
        "title": { "type": "string", "maxLength": 512, "required": true },
        "category": { "type": "string", "enum": ["Content Marketing", "Product Marketing", "Demand Generation", "Sales Enablement", "Customer Marketing", "Website & CRO", "Market Research", "Analytics & Reporting", "Campaign Management", "Operations"], "required": true },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"], "required": true },
        "notes": { "type": "string", "maxLength": 4096, "required": false },
        "createdAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$", "required": true }
      }
    },
    "kpiActuals": {
      "path": "users/{userId}/kpiActuals/{monthKey}",
      "description": "Monthly conversion performance inputs and targets",
      "fields": {
        "monthKey": { "type": "string", "pattern": "^\\d{4}-\\d{2}$", "required": true },
        "leadsActual": { "type": "number", "minimum": 0, "required": true },
        "mqlsActual": { "type": "number", "minimum": 0, "required": true },
        "webConvActual": { "type": "number", "minimum": 0, "required": true },
        "emailContactsActual": { "type": "number", "minimum": 0, "required": true }
      }
    }
  }
}
