rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser(userId) {
      return isSignedIn() && 
             request.auth.uid == userId && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && 
             id.size() <= 128 && 
             id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- COLLECTION RULES ---

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isVerifiedUser(userId) && isValidId(userId);
      
      allow create: if isVerifiedUser(userId) && 
                       isValidId(userId) && 
                       incoming().keys().hasAll(['email', 'createdAt', 'updatedAt']) && 
                       incoming().keys().size() == 3 &&
                       incoming().email is string && 
                       incoming().email.size() <= 256 &&
                       incoming().createdAt == request.time && 
                       incoming().updatedAt == request.time;

      allow update: if isVerifiedUser(userId) && 
                       isValidId(userId) && 
                       incoming().email is string && 
                       incoming().email.size() <= 256 &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['email', 'updatedAt']);

      allow delete: if false; // User accounts are durable and cannot be deleted from the client SDK

      // 2. Subcollection: Tasks
      match /tasks/{taskId} {
        allow list: if isVerifiedUser(userId);
        allow get: if isVerifiedUser(userId) && isValidId(taskId);

        // Validation helper for Task Entity
        function isValidTask(data) {
          return data.id is string && 
                 data.id.size() <= 128 &&
                 data.date is string && 
                 data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
                 data.title is string && 
                 data.title.size() <= 512 &&
                 data.category in ["Content Marketing", "Product Marketing", "Demand Generation", "Sales Enablement", "Customer Marketing", "Website & CRO", "Market Research", "Analytics & Reporting", "Campaign Management", "Operations"] &&
                 data.status in ["To Do", "In Progress", "Done"] &&
                 data.priority in ["High", "Medium", "Low"] &&
                 data.isCaseStudyOrInsight is bool &&
                 (!('notes' in data) || (data.notes is string && data.notes.size() <= 4096)) &&
                 (!('duration' in data) || (data.duration is string && data.duration.size() <= 64)) &&
                 (!('deliverableLink' in data) || (data.deliverableLink is string && data.deliverableLink.size() <= 2048)) &&
                 (!('kpiImpact' in data) || (data.kpiImpact in ["Social Content", "Email Campaign", "Sales Asset / Case Study", "None"]));
        }

        allow create: if isVerifiedUser(userId) && 
                         isValidId(taskId) && 
                         incoming().id == taskId &&
                         isValidTask(incoming()) &&
                         incoming().keys().hasAll(['id', 'date', 'title', 'category', 'status', 'priority', 'isCaseStudyOrInsight']) &&
                         // Prevent extra ghost fields on creation
                         incoming().keys().size() <= 11;

        allow update: if isVerifiedUser(userId) && 
                         isValidId(taskId) && 
                         incoming().id == existing().id &&
                         isValidTask(incoming()) &&
                         incoming().id == existing().id;

        allow delete: if isVerifiedUser(userId) && isValidId(taskId);
      }

      // 3. Subcollection: BacklogTasks
      match /backlogTasks/{backlogId} {
        allow list: if isVerifiedUser(userId);
        allow get: if isVerifiedUser(userId) && isValidId(backlogId);

        // Validation helper for Backlog Task Entity
        function isValidBacklogTask(data) {
          return data.id is string && 
                 data.id.size() <= 128 &&
                 data.title is string && 
                 data.title.size() <= 512 &&
                 data.category in ["Content Marketing", "Product Marketing", "Demand Generation", "Sales Enablement", "Customer Marketing", "Website & CRO", "Market Research", "Analytics & Reporting", "Campaign Management", "Operations"] &&
                 data.priority in ["High", "Medium", "Low"] &&
                 data.createdAt is string && 
                 data.createdAt.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
                 (!('notes' in data) || (data.notes is string && data.notes.size() <= 4096));
        }

        allow create: if isVerifiedUser(userId) && 
                         isValidId(backlogId) && 
                         incoming().id == backlogId &&
                         isValidBacklogTask(incoming()) &&
                         incoming().keys().hasAll(['id', 'title', 'category', 'priority', 'createdAt']) &&
                         incoming().keys().size() <= 6;

        allow update: if isVerifiedUser(userId) && 
                         isValidId(backlogId) && 
                         incoming().id == existing().id &&
                         isValidBacklogTask(incoming());

        allow delete: if isVerifiedUser(userId) && isValidId(backlogId);
      }

      // 4. Subcollection: KpiActuals
      match /kpiActuals/{monthKey} {
        allow list: if isVerifiedUser(userId);
        allow get: if isVerifiedUser(userId) && isValidId(monthKey);

        // Validation helper for Monthly KPI Actuals Entity
        function isValidKpiActual(data) {
          return data.monthKey is string && 
                 data.monthKey.matches('^\\d{4}-\\d{2}$') &&
                 data.leadsActual is int && data.leadsActual >= 0 &&
                 data.mqlsActual is int && data.mqlsActual >= 0 &&
                 data.webConvActual is number && data.webConvActual >= 0 &&
                 data.emailContactsActual is int && data.emailContactsActual >= 0;
        }

        allow create: if isVerifiedUser(userId) && 
                         isValidId(monthKey) && 
                         incoming().monthKey == monthKey &&
                         isValidKpiActual(incoming()) &&
                         incoming().keys().hasAll(['monthKey', 'leadsActual', 'mqlsActual', 'webConvActual', 'emailContactsActual']) &&
                         incoming().keys().size() == 5;

        allow update: if isVerifiedUser(userId) && 
                         isValidId(monthKey) && 
                         incoming().monthKey == existing().monthKey &&
                         isValidKpiActual(incoming());

        allow delete: if isVerifiedUser(userId) && isValidId(monthKey);
      }
    }
  }
}
